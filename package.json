{
  "name": "spendwise-desktop",
  "version": "1.0.0",
  "description": "Local-first personal finance desktop app: import bank CSVs, auto-categorize, visualize, and query your spending in plain English",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "cross-env SPENDWISE_WEB=1 vite",
    "build": "npm run typecheck && vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "build:web": "cross-env SPENDWISE_WEB=1 vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx,ts,tsx --fix"
  },
  "keywords": [
    "electron",
    "react",
    "finance",
    "personal-finance",
    "desktop-app",
    "csv-import",
    "analytics"
  ],
  "author": "SpendWise Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.4",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.8.0",
    "tailwind-merge": "^2.0.0"
  },
  "build": {
    "appId": "com.spendwise.desktop",
    "productName": "SpendWise",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  }
}
